# Invoked as: cmake -P embed_lba2_cfg.cmake -DINPUT=<path> -DOUTPUT=<path>
# Emits C++ source with embedded LBA2.CFG bytes (no Python required).
if(NOT DEFINED INPUT OR NOT DEFINED OUTPUT)
    message(FATAL_ERROR "embed_lba2_cfg.cmake requires -DINPUT= and -DOUTPUT=")
endif()

file(READ "${INPUT}" _hex HEX)
string(LENGTH "${_hex}" _hexlen)
math(EXPR _nbytes "${_hexlen} / 2")

set(_lines "// Generated by cmake/embed_lba2_cfg.cmake - do not edit\n")
string(APPEND _lines "#include <SYSTEM/ADELINE_TYPES.H>\n\n")
string(APPEND _lines "extern \"C\" const unsigned char g_embeddedLba2CfgBytes[] = {\n")

if(_nbytes EQUAL 0)
    string(APPEND _lines "\n")
else()
    math(EXPR _last "${_nbytes} - 1")
    set(_row "")
    set(_col 0)
    foreach(_i RANGE 0 ${_last})
        math(EXPR _off "${_i} * 2")
        string(SUBSTRING "${_hex}" ${_off} 2 _byte)
        if(_col GREATER 0)
            string(APPEND _row ", ")
        endif()
        string(APPEND _row "0x${_byte}")
        math(EXPR _col "${_col} + 1")
        if(_col EQUAL 16)
            string(APPEND _lines "    ${_row},\n")
            set(_row "")
            set(_col 0)
        endif()
    endforeach()
    if(_col GREATER 0)
        string(APPEND _lines "    ${_row},\n")
    endif()
endif()

string(APPEND _lines "};\n\n")
string(APPEND _lines "extern \"C\" const U32 g_embeddedLba2CfgBytesSize = (U32)sizeof(g_embeddedLba2CfgBytes);\n")

file(WRITE "${OUTPUT}" "${_lines}")
